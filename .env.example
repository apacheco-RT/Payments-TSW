# Required — PostgreSQL connection string
# On Replit: set this in the Secrets tab (not here)
# Locally: point to your local or remote Postgres instance
DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# Optional — defaults to 5000
PORT=5000

# Required for npm install — GitHub PAT with read:packages scope
# @ds-foundation/tokens is hosted on GitHub Packages; this token authenticates access.
# On Replit: add this in the Secrets tab (key: NODE_AUTH_TOKEN)
# Locally: export NODE_AUTH_TOKEN=<your-token> before running npm install
NODE_AUTH_TOKEN=
